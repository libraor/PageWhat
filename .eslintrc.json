{
  "env": {
    "browser": true,
    "es2021": true,
    "webextensions": true
  },
  "extends": ["eslint:recommended"],
  "parserOptions": {
    "ecmaVersion": 2021,
    "sourceType": "module"
  },
  "rules": {
    // 代码风格
    "quotes": ["error", "single"],
    "semi": ["error", "always"],

    // 变量声明
    "no-var": "error",
    "prefer-const": "error",
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],

    // 最佳实践
    "eqeqeq": ["error", "always"],
    "curly": ["error", "all"],
    "default-case": "error",
    "no-empty": ["error", { "allowEmptyCatch": true }],
    "no-fallthrough": "error",
    "no-implicit-coercion": "warn",
    "no-implicit-globals": "error",
    "no-loop-func": "error",
    "no-prototype-builtins": "warn",
    "no-script-url": "error",
    "no-undef": "error",
    "no-unreachable": "error",
    "use-isnan": "error",

    // 复杂性控制
    "complexity": ["warn", { "max": 10 }],
    "max-depth": ["warn", { "max": 4 }],
    "max-nested-callbacks": ["warn", { "max": 3 }],
    "max-params": ["warn", { "max": 5 }],

    // Manifest V3 特定规则
    "no-restricted-globals": ["error", "window", "document"],
    "no-restricted-syntax": [
      "error",
      {
        "selector": "ImportExpression",
        "message": "Manifest V3 Service Worker 不支持动态 import()"
      }
    ]
  },
  "globals": {
    "chrome": "readonly",
    "browser": "readonly"
  },
  "overrides": [
    {
      "files": ["popup/**/*.js", "options/**/*.js", "offscreen/**/*.js"],
      "rules": {
        "no-restricted-globals": "off"
      }
    },
    {
      "files": ["lib/checker.js"],
      "rules": {
        "no-restricted-globals": ["error", "window"]
      }
    }
  ]
}
